{
  "name": "arxiv-scholar-mcp",
  "phase": 1,
  "status": "scaffolded",
  "tools": [
    {
      "name": "search_papers",
      "zodSchema": "z.object({ query: z.string().min(3).max(300), limit: z.number().int().min(1).max(50).default(10) }).strict()"
    },
    {
      "name": "get_paper",
      "zodSchema": "z.object({ paper_id: z.string().min(3).max(128) }).strict()"
    },
    {
      "name": "list_recent",
      "zodSchema": "z.object({ category: z.string().min(2).max(32), limit: z.number().int().min(1).max(50).default(20) }).strict()"
    }
  ],
  "rateLimit": {
    "requestsPerSecond": 1,
    "burst": 5,
    "retryPolicy": "bounded_exponential_backoff"
  }
}
