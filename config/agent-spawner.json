{
  "schemaVersion": "phase18-agent-spawner-v1",
  "enabled": false,
  "requireLiveVerificationEvidence": true,
  "plannerVersion": "phase18-planner-v1",
  "finalSynthesisMode": "orchestrator_aggregation",
  "missionExecution": {
    "maxRuntimeMs": 1800000,
    "defaultSubtaskTimeoutMs": 300000,
    "stallIntervalMs": 120000,
    "schedulerTickMs": 250
  },
  "checkpointing": {
    "enabled": true,
    "completedSubtaskThreshold": 4,
    "stageBoundaries": true
  },
  "laneScaling": {
    "enabled": true,
    "scaleStep": 1
  },
  "defaultLaneMinInflight": 1,
  "defaultLaneMaxInflight": 1,
  "laneDefaults": {
    "perRoleMin": {
      "scout": 1,
      "analyst": 1,
      "synthesizer": 1,
      "operator": 1
    },
    "perRoleMax": {
      "scout": 2,
      "analyst": 2,
      "synthesizer": 1,
      "operator": 1
    }
  },
  "missionWorkspaceDir": "workspace/missions",
  "runtimeStatePath": "state/runtime/state.json",
  "liveEvidence": {
    "llmSummaryPath": "audit/evidence/live-llm/summary-latest.json",
    "mcpSummaryPath": "audit/evidence/mcp-live/summary-latest.json"
  },
  "skillConfig": {
    "hostedSkillsEnabled": false,
    "sources": {
      "bundled": [
        "skills"
      ],
      "shared": [
        "$CODEX_HOME/skills",
        "~/.codex/skills"
      ],
      "workspace": [
        ".codex/skills",
        "workspace/skills"
      ]
    }
  }
}
