# Archived to keep validation local-only. Run `npm run verify:live-llm` and `npm run verify:live-mcp` manually when needed.
name: live-verification

on:
  workflow_dispatch:
    inputs:
      run_live_llm:
        description: "Run live LLM provider verification harness"
        required: true
        default: true
        type: boolean
      run_live_mcp:
        description: "Run live MCP connector verification harness"
        required: true
        default: true
        type: boolean
      llm_providers:
        description: "Comma-separated provider list for live LLM verification"
        required: false
        default: "local,openai,anthropic,openrouter"
        type: string
      mcp_providers:
        description: "Comma-separated provider list for live MCP verification"
        required: false
        default: "arxiv,semantic-scholar"
        type: string

permissions:
  contents: read

jobs:
  live-verification:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node 22.13.1
        uses: actions/setup-node@v4
        with:
          node-version: 22.13.1

      - name: Offline install (ignore scripts)
        run: npm ci --offline --ignore-scripts --cache ./.ci/npm-cache

      - name: Generate Phase 1 evidence map
        run: node scripts/generate-phase1-evidence-map.js

      - name: Run live LLM verification
        if: ${{ inputs.run_live_llm }}
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          OPENROUTER_API_KEY: ${{ secrets.OPENROUTER_API_KEY }}
        run: |
          node scripts/run-live-llm-verification.js \
            --providers "${{ inputs.llm_providers }}"

      - name: Run live MCP verification
        if: ${{ inputs.run_live_mcp }}
        run: |
          node scripts/run-live-mcp-verification.js \
            --providers "${{ inputs.mcp_providers }}"

      - name: Upload live LLM evidence
        if: ${{ always() && inputs.run_live_llm }}
        uses: actions/upload-artifact@v4
        with:
          name: live-llm-evidence
          path: audit/evidence/live-llm/
          if-no-files-found: warn

      - name: Upload live MCP evidence
        if: ${{ always() && inputs.run_live_mcp }}
        uses: actions/upload-artifact@v4
        with:
          name: live-mcp-evidence
          path: audit/evidence/mcp-live/
          if-no-files-found: warn

      - name: Upload Phase 1 evidence map
        if: ${{ always() }}
        uses: actions/upload-artifact@v4
        with:
          name: phase1-evidence-map
          path: audit/evidence/history/
          if-no-files-found: warn
